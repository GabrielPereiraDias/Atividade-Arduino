// C++

int LED = 2;
int BOTAO = 3;
int LED2 = 10;
int BOTAO2 = 11;

// Variáveis 
int ESTADO_LED = 0; 
int VAR = 0;        
int VAR_ANT = 0;    

int ESTADO_LED2 = 0; 
int VAR2 = 0;       
int VAR2_ANT = 0;  

void setup() {
  pinMode(LED, OUTPUT);
  pinMode(BOTAO, INPUT);
  
  // novos pinos
  pinMode(LED2, OUTPUT);
  pinMode(BOTAO2, INPUT);
}

void loop() {
  // --- LED 1 ---
  VAR = digitalRead(BOTAO); 

  if (VAR == HIGH && VAR_ANT == LOW) {
    ESTADO_LED = 1 - ESTADO_LED; 
    delay(50); // 
  }
  VAR_ANT = VAR; 

  if (ESTADO_LED == 1) {
    digitalWrite(LED, HIGH);
  } else {
    digitalWrite(LED, LOW);
  }

  // --- LED 2 ---
  VAR2 = digitalRead(BOTAO2); 

  // transição para o segundo botão
  if (VAR2 == HIGH && VAR2_ANT == LOW) {
    // fazer o led piscar antes de acender (simulando falha)
    ESTADO_LED2 = 1 - ESTADO_LED2; 
    delay(50);
    digitalWrite(LED2, HIGH);
  delay(200);
  digitalWrite(LED2, LOW);
  delay(200);
  }
  VAR2_ANT = VAR2; 

  if (ESTADO_LED2 == 1) {
    digitalWrite(LED2, HIGH);
  } else {
    digitalWrite(LED2, LOW);
  }
}

