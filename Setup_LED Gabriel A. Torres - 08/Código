// C++

int portLed = 10;
int portLed2 = 11;
int portLed3 = 6;
int portLed4 = 5;

void setup() {
  // Iniciar os pins como saídas 
  pinMode(portLed, OUTPUT);
  pinMode(portLed2, OUTPUT);
  pinMode(portLed3, OUTPUT);
  pinMode(portLed4, OUTPUT);
}

void loop() 
{
  //Criação de ritmo com as luzes ✴
  // Acender o LED azul com mais duração 
  digitalWrite(portLed, HIGH);
  delay(1500);
  digitalWrite(portLed, LOW);
  delay(1500);

  // Piscar o LED azul 
  digitalWrite(portLed, HIGH);
  delay(200);
  digitalWrite(portLed, LOW);
  delay(200);
  
  // Piscar o LED vermelho
